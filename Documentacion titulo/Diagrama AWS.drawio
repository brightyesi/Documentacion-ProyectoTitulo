        <mxCell id="tabla" parent="1" style="text;html=1;strokeColor=#232F3E;fillColor=#ffffff;align=left;verticalAlign=top;spacingLeft=5;spacingRight=5;overflow=hidden;rotatable=0;whiteSpace=wrap;" value="&lt;table border=&#39;1&#39; style=&#39;border-collapse:collapse;font-size:11px;width:100%&#39;&gt; &lt;tr style=&#39;background:#232F3E;color:#FF9900&#39;&gt;   &lt;th style=&#39;padding:5px&#39;&gt;Servicio&lt;/th&gt;   &lt;th style=&#39;padding:5px&#39;&gt;Límite gratis&lt;/th&gt;   &lt;th style=&#39;padding:5px&#39;&gt;Uso en proyecto&lt;/th&gt; &lt;/tr&gt; &lt;tr&gt;   &lt;td style=&#39;padding:4px&#39;&gt;Elastic Beanstalk&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;EC2 t2.micro — 750 h/mes&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;Spring Boot (.jar)&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&#39;background:#f5f5f5&#39;&gt;   &lt;td style=&#39;padding:4px&#39;&gt;Amazon RDS&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;db.t3.micro — 750 h/mes&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;PostgreSQL agricola_db&lt;/td&gt; &lt;/tr&gt; &lt;tr&gt;   &lt;td style=&#39;padding:4px&#39;&gt;Amazon S3&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;5 GB almacenamiento&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;PDFs e imágenes facturas&lt;/td&gt; &lt;/tr&gt; &lt;tr style=&#39;background:#f5f5f5&#39;&gt;   &lt;td style=&#39;padding:4px&#39;&gt;Amazon VPC&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;Siempre gratis&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;Red privada interna&lt;/td&gt; &lt;/tr&gt; &lt;tr&gt;   &lt;td style=&#39;padding:4px&#39;&gt;IAM&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;Siempre gratis&lt;/td&gt;   &lt;td style=&#39;padding:4px&#39;&gt;Permisos y roles&lt;/td&gt; &lt;/tr&gt; &lt;/table&gt;" vertex="1">
