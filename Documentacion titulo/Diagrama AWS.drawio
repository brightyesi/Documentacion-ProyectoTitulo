        <mxCell id="s3_desc" parent="aws_box" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#569A31;fontSize=10;" value="Bucket de archivos&lt;br&gt;&lt;font style=&#39;font-size:10px&#39;&gt;• PDFs e imágenes de facturas&lt;br&gt;• 5 GB gratis (Free Tier)&lt;br&gt;• URL única por archivo&lt;br&gt;• Acceso privado (solo backend)&lt;/font&gt;" vertex="1">
